# Runtime
NODE_ENV=development

# Web (Next.js)
NEXT_PUBLIC_APP_NAME=Residente
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=change-me
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_RELEASE=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# Backend (NestJS)
PORT=3001
API_PREFIX=api
CORS_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/residente?schema=public
JWT_SECRET=change-me
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_EXPIRES_IN=1d
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.05
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT_JSON=

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=residente
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Mobile (Flutter)
MOBILE_API_URL=http://10.0.2.2:3001
MOBILE_SUPABASE_URL=https://your-project.supabase.co
MOBILE_SUPABASE_PUBLISHABLE_KEY=change-me
MOBILE_SENTRY_DSN=
MOBILE_SENTRY_ENVIRONMENT=development
MOBILE_SENTRY_RELEASE=
MOBILE_SENTRY_TRACES_SAMPLE_RATE=0.1
MOBILE_FIREBASE_SENDER_ID=

# Web Push / Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Supabase Storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=change-me
SUPABASE_STORAGE_BUCKET=media
SUPABASE_STORAGE_PUBLIC=true
SUPABASE_STORAGE_MAX_FILE_SIZE_BYTES=10485760

# Billing
WEB_URL=http://localhost:3000
MERCADOPAGO_ACCESS_TOKEN=change-me
MERCADOPAGO_WEBHOOK_URL=http://localhost:3001/api/billing/webhook/mercadopago
MERCADOPAGO_CURRENCY=USD
PRO_PRICE=9
